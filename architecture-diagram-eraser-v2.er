  Amazon S3 Report [icon: aws-s3]
  S3 Event Report [icon: aws-lambda]
  Lambda Trigger Report [icon: aws-lambda]
}

REAL-TIME INGESTION [icon: zap, color: red] {
  EMR Spark Streaming [icon: aws-emr]
}

REAL-TIME EMR ORCHESTRATION [icon: clock, color: red] {
  EventBridge Cron 30min [icon: aws-eventbridge]
  Lambda EMR Manager [icon: aws-lambda]
}

